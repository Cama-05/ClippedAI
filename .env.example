# HuggingFace API Token for speaker diarization
# Get your token at: https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=your_huggingface_token_here

# Groq API Key for viral title generation
# Get your key at: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# LLM provider for metadata generation: groq or openai
LLM_PROVIDER=groq

# OpenAI API configuration (used only when LLM_PROVIDER=openai)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# YouTube Shorts Duration Settings (in seconds)
MIN_CLIP_DURATION=45  # Minimum duration in seconds for YouTube Shorts
MAX_CLIP_DURATION=120  # Maximum duration in seconds for YouTube Shorts

# Transcription Model Settings
TRANSCRIPTION_MODEL=medium  # Options: tiny, base, small, medium, large-v1, large-v2

# Aspect Ratio for YouTube Shorts (width:height)
ASPECT_RATIO_WIDTH=9
ASPECT_RATIO_HEIGHT=16

# Optional logo overlay for exported clips
# Pass the logo at runtime with: python main.py --logo-url "https://.../logo.png"
LOGO_OPACITY=0.55
LOGO_WIDTH_RATIO=0.50
LOGO_EDGE_MARGIN=70